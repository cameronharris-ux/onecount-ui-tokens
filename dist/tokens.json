{
  "$comment": "Canonical OneCount design tokens. The single source of truth for the family's palette, type, spacing and radius. SHARED CORE (brand/ai accent + fonts + pill) is identical for all 6 products and is strictly gated. The two named THEME presets capture the genuine, intentional split between the sibling apps and the OneCount-inventory family; each app pins to one preset so values can't drift accidentally and can be converged value-by-value over time.",
  "version": "0.2.0",
  "core": {
    "accent": "#00E39A",
    "accentDark": "#00A66E",
    "ai": "#FF2E8A",
    "fonts": {
      "display": "SpaceGrotesk_600SemiBold",
      "displayBold": "SpaceGrotesk_700Bold",
      "displayMedium": "SpaceGrotesk_500Medium",
      "body": "Inter_400Regular",
      "medium": "Inter_500Medium",
      "semibold": "Inter_600SemiBold",
      "bold": "Inter_700Bold",
      "mono": "JetBrainsMono_500Medium"
    },
    "radiusPill": 999
  },
  "themes": {
    "sibling": {
      "$apps": [
        "playbook",
        "ops",
        "shield",
        "trace"
      ],
      "background": "#0A0F1A",
      "status": {
        "success": "#059669",
        "successDark": "#34D399",
        "warning": "#E0A309",
        "warningDark": "#F0B429",
        "danger": "#E5484D",
        "dangerDark": "#FF6369",
        "info": "#00A8FF"
      },
      "spacing": {
        "xs": 4,
        "sm": 8,
        "md": 12,
        "lg": 16,
        "xl": 24,
        "xxl": 32,
        "xxxl": 48
      },
      "radius": {
        "sm": 10,
        "md": 14,
        "lg": 18,
        "xl": 24,
        "pill": 999
      }
    },
    "onecount": {
      "$apps": [
        "onecount-app",
        "hub"
      ],
      "background": "#0A0F1A",
      "status": {
        "success": "#059669",
        "successDark": "#34D399",
        "warning": "#FFB020",
        "warningDark": "#FBBF24",
        "danger": "#FF4757",
        "dangerDark": "#FF6B7A",
        "info": "#3B82F6"
      },
      "spacing": {
        "xs": 8,
        "sm": 12,
        "md": 16,
        "lg": 20,
        "xl": 24
      },
      "radius": {
        "sm": 6,
        "md": 8,
        "lg": 12,
        "xl": 16,
        "pill": 999
      }
    }
  },
  "appThemes": {
    "playbook": "sibling",
    "ops": "sibling",
    "shield": "sibling",
    "trace": "sibling",
    "onecount-app": "onecount",
    "hub": "onecount"
  }
}