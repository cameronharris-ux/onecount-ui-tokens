{
  "$comment": "Canonical OneCount design tokens. Version 0.3.0 revives Option B from hospitality-os-2026-07 doc 10: this package is the literal source for audited values, extended schema constants, and drift/contrast checks. Runtime adapters stay local to each app.",
  "version": "0.6.0",
  "core": {
    "accent": "#00E39A",
    "accentDark": "#00A66E",
    "ai": "#FF2E8A",
    "radiusPill": 999,
    "brand": {
      "$comment": "D1/D3 ratified values. Electric Mint is the family action color; magenta is reserved for LLM-derived output only.",
      "accent": "#00E39A",
      "accentDark": "#00A66E",
      "accentSoft": "#E2FAF1",
      "accentSoftDark": "#0E2A21",
      "onAccent": "#04231A",
      "primaryGlow": "#2EFFB4",
      "primaryDeep": "#00A66E",
      "ai": "#FF2E8A",
      "aiGlow": "#FF6BAE",
      "aiDeep": "#B81E63",
      "tealBridge": "#46C8CC",
      "gradient": [
        "#00F4AC",
        "#3FC6CE",
        "#FF3D93"
      ]
    },
    "fonts": {
      "display": "SpaceGrotesk_600SemiBold",
      "displayBold": "SpaceGrotesk_700Bold",
      "displayMedium": "SpaceGrotesk_500Medium",
      "body": "Inter_400Regular",
      "medium": "Inter_500Medium",
      "semibold": "Inter_600SemiBold",
      "bold": "Inter_700Bold",
      "mono": "JetBrainsMono_500Medium",
      "monoMedium": "JetBrainsMono_500Medium",
      "monoBold": "JetBrainsMono_700Bold"
    },
    "typography": {
      "display": {
        "fontSize": 34,
        "fontWeight": 700,
        "lineHeight": 40,
        "fontFamily": "SpaceGrotesk_700Bold"
      },
      "screenTitle": {
        "fontSize": 28,
        "fontWeight": 700,
        "lineHeight": 34,
        "fontFamily": "SpaceGrotesk_700Bold"
      },
      "h1": {
        "fontSize": 26,
        "fontWeight": 700,
        "lineHeight": 32,
        "fontFamily": "SpaceGrotesk_700Bold"
      },
      "h2": {
        "fontSize": 22,
        "fontWeight": 700,
        "lineHeight": 28,
        "fontFamily": "SpaceGrotesk_700Bold"
      },
      "h3": {
        "fontSize": 18,
        "fontWeight": 600,
        "lineHeight": 24,
        "fontFamily": "SpaceGrotesk_600SemiBold"
      },
      "body": {
        "fontSize": 15,
        "fontWeight": 400,
        "lineHeight": 22,
        "fontFamily": "Inter_400Regular"
      },
      "bodySmall": {
        "fontSize": 13,
        "fontWeight": 400,
        "lineHeight": 18,
        "fontFamily": "Inter_400Regular"
      },
      "caption": {
        "fontSize": 12,
        "fontWeight": 500,
        "lineHeight": 16,
        "fontFamily": "Inter_500Medium"
      },
      "label": {
        "fontSize": 11,
        "fontWeight": 600,
        "lineHeight": 14,
        "fontFamily": "Inter_600SemiBold",
        "textTransform": "uppercase",
        "letterSpacing": 1.3
      },
      "heroNumber": {
        "fontSize": 44,
        "fontWeight": 800,
        "lineHeight": 50,
        "fontFamily": "JetBrainsMono_700Bold",
        "letterSpacing": -1,
        "fontVariant": [
          "tabular-nums"
        ]
      },
      "MIN_FONT_SIZE": 11
    },
    "spacingRules": {
      "screenGutter": 18,
      "cardGap": 14,
      "sectionLabelGap": 26,
      "baseGrid": 4,
      "cardPadding": 16,
      "cardPaddingTight": 13
    },
    "spacingScales": {
      "$comment": "Rules unify; numeric app scales stay distinct. OneCount's canonical internal oc.space scale is carried here while the onecount theme also records the exported lib/theme.ts spacing adapter.",
      "siblings": {
        "xs": 4,
        "sm": 8,
        "md": 12,
        "lg": 16,
        "xl": 24,
        "xxl": 32,
        "xxxl": 48
      },
      "onecountCanonical": {
        "xxs": 4,
        "xs": 8,
        "sm": 12,
        "md": 16,
        "lg": 20,
        "xl": 28,
        "xxl": 40
      }
    },
    "radius": {
      "sm": 10,
      "md": 14,
      "lg": 18,
      "xl": 24,
      "pill": 999
    },
    "elevation": {
      "none": {
        "elevation": 0
      },
      "sm": {
        "y": 2,
        "opacity": 0.12,
        "radius": 8,
        "elevation": 2
      },
      "md": {
        "y": 4,
        "opacity": 0.2,
        "radius": 12,
        "elevation": 6
      },
      "lg": {
        "y": 8,
        "opacity": 0.3,
        "radius": 24,
        "elevation": 12
      },
      "heroPrimary": {
        "color": "#00E39A",
        "y": 6,
        "opacity": 0.35,
        "radius": 24,
        "elevation": 10
      },
      "heroAccent": {
        "color": "#FF2E8A",
        "y": 6,
        "opacity": 0.3,
        "radius": 28,
        "elevation": 10,
        "$comment": "AI-only magenta halo; opacity/radius match one-count-app/lib/theme.ts."
      }
    },
    "keyline": {
      "alpha": 0.09,
      "$comment": "1px neutral card keyline: withAlpha(text, 0.09)."
    },
    "motion": {
      "micro": {
        "durationMs": [
          120,
          200
        ],
        "easing": "ease-out",
        "pressScaleButton": 0.985,
        "pressScaleCard": 0.992
      },
      "standard": {
        "durationMs": [
          240,
          300
        ],
        "easing": "cubic-out"
      },
      "springs": {
        "damping": [
          12,
          18
        ],
        "stiffness": [
          120,
          200
        ]
      },
      "dataReveal": {
        "durationMs": [
          600,
          700
        ],
        "easing": "cubic-out"
      },
      "skeletonShimmer": {
        "durationMs": 1400,
        "loop": true,
        "easing": "inOut(ease)"
      },
      "ambient": {
        "durationMs": 18000,
        "easing": "linear"
      },
      "exitRatio": [
        0.6,
        0.7
      ],
      "$comment": "Audit ENVELOPE (allowed ranges) used by design-guardian checks. Runtime values live in motionSpec; every motionSpec duration/exitRatio sits inside these ranges. Press/release springs are a deliberate exception to the springs range - see motionSpec.spring.$comment."
    },
    "motionSpec": {
      "$comment": "OneCount Motion System v1.0 runtime scale (onecount-ui/docs/MOTION.md). Concrete single values apps and @onecount/ui consume directly. Never hardcode a duration/easing/spring/scale a token already names.",
      "duration": {
        "instant": 120,
        "fast": 160,
        "standard": 220,
        "nav": 280,
        "expand": 340,
        "data": 650,
        "brand": 900,
        "splash": 1450
      },
      "exitRatio": 0.65,
      "easing": {
        "$comment": "cubic-bezier control points [x1,y1,x2,y2]. standard=out-cubic workhorse; enter=out-quint large surfaces; exit=out-quad departures; emphasized=out-expo hero/brand/data; move=in-out-cubic on-screen movement; linear=progress/scan-line only.",
        "standard": [0.215, 0.61, 0.355, 1],
        "enter": [0.23, 1, 0.32, 1],
        "exit": [0.25, 0.46, 0.45, 0.94],
        "emphasized": [0.19, 1, 0.22, 1],
        "move": [0.645, 0.045, 0.355, 1],
        "linear": [0, 0, 1, 1]
      },
      "spring": {
        "$comment": "soft=sheets/drag-release/layout settle; precise=lock-in/toggles/indicators (<=2% overshoot); press/release=PressableScale feel (proven values, deliberately stiffer than the motion.springs layout envelope).",
        "soft": { "damping": 18, "stiffness": 160, "mass": 1 },
        "precise": { "damping": 26, "stiffness": 300, "mass": 0.9 },
        "press": { "damping": 18, "stiffness": 320, "mass": 0.6 },
        "release": { "damping": 14, "stiffness": 220, "mass": 0.7 }
      },
      "distance": {
        "micro": 2,
        "sm": 4,
        "md": 8,
        "lg": 16,
        "xl": 24
      },
      "scale": {
        "pressButton": 0.985,
        "pressCard": 0.992,
        "enter": 0.97,
        "popover": 0.95,
        "emphasis": 1.02
      },
      "opacity": {
        "backdrop": 0.45,
        "dimmed": 0.7
      },
      "splashStages": {
        "$comment": "BrandSplash choreography clock (ms from mount). Stage 5 handoff ends at duration.splash; hard ceiling 1800; reduce-motion path is fade-in/hold/fade-out under 900 total.",
        "environment": [0, 120],
        "construction": [80, 700],
        "lockIn": [700, 880],
        "identity": [860, 1220],
        "handoff": [1150, 1450],
        "segmentStaggerMs": 40,
        "segmentDurationMs": 380
      }
    },
    "componentState": {
      "pressScale": 0.985,
      "pressOpacity": 0.88,
      "disabledOpacity": 0.42
    },
    "icons": {
      "$comment": "Outline only; no filled or duotone icon glyphs. Fill is reserved for status dots and the AI-magenta accent, never for the icon glyph itself.",
      "sizes": {
        "inline": 16,
        "default": 20,
        "emphasis": 24
      },
      "strokeWidth": 1.75
    },
    "a11y": {
      "MIN_TAP_TARGET": 44,
      "MIN_TAP_TARGET_ANDROID": 48,
      "MIN_FONT_SIZE": 11,
      "CONTRAST_FLOOR": 4.5,
      "DISABLED_OPACITY": 0.42,
      "focusRing": {
        "color": "rgba(0,227,154,0.50)",
        "width": 2
      }
    },
    "haptics": {
      "$comment": "Shared cross-app moment vocabulary consumed via @onecount/ui hapticMoment(). selection = selectionAsync tick, safe for high-frequency loops. brand-lock-in fires once per cold start at splash mark settle, never elsewhere.",
      "button-press": "light",
      "quantity-step": "selection",
      "scale-settled": "selection",
      "scan-matched": "medium",
      "count-saved": "success",
      "action-succeeded": "success",
      "action-needs-review": "warning",
      "action-failed": "error",
      "destructive-confirmed": "strong",
      "brand-lock-in": "light"
    },
    "identityHues": {
      "$comment": "Per-product hue appears only as a dot, icon accent, or <=12% wash. Never buttons, tab bars, status, nav chrome, or text links. onecount-site/lib/ecosystem.ts still ships OneCount as #00D68F; v0.3.0 keeps D1 brand mint here and reports that source drift.",
      "onecount": "#00E39A",
      "ops": "#56A9FF",
      "shield": "#FFB224",
      "trace": "#2DD4BF",
      "pulse": "#A78BFA"
    },
    "siteGrid": {
      "mobile": {
        "maxWidth": 639,
        "columns": 4,
        "gutter": 16,
        "margin": 16
      },
      "tablet": {
        "minWidth": 640,
        "maxWidth": 1023,
        "columns": 8,
        "gutter": 20,
        "margin": 24
      },
      "desktop": {
        "minWidth": 1024,
        "columns": 12,
        "gutter": 24,
        "margin": 32
      }
    }
